int main()
{
    *heartbeat_ptr = 0xDEADBEE1;

    extern u32 _vector_table;

    /* 1. 安全配置 VBAR，将中断向量表指向 DDR
     * 这样 IPI 中断触发时，CPU 就能精准找到处理函数，再也不会迷失在 TCM！ */
    __asm__ volatile(
        "mrc p15, 0, r0, c1, c0, 0 \n"
        "bic r0, r0, #(1<<13)      \n"  /* 清除 V 位 */
        "mcr p15, 0, r0, c1, c0, 0 \n"
        "mcr p15, 0, %0, c12, c0, 0\n"  /* 把 _vector_table 的地址写入 VBAR */
        "isb                       \n"
        "dsb                       \n"
        : : "r"((u32)&_vector_table) : "r0"
    );

    /* 2. 开启 FPU (必须保留，防止 ThreadX 浮点指令死机) */
    __asm__ volatile(
        "mrc p15, 0, r0, c1, c0, 2 \n"
        "orr r0, r0, #(0xF << 20)  \n"
        "mcr p15, 0, r0, c1, c0, 2 \n"
        "isb                       \n"
        "vmrs r0, fpexc            \n"
        "orr r0, r0, #(1<<30)      \n"
        "vmsr fpexc, r0            \n"
        : : : "r0"
    );

    /* 3. 初始化平台 (开启 MPU, Cache, UART) */
    init_platform();

    *heartbeat_ptr = 0xDEADBEE2;

    /* 4. 启动 ThreadX 调度器 */
    tx_kernel_enter();

    return 0;
}
