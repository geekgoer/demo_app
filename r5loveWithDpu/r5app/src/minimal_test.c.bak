/*
 * Minimal test program for R5 in AMP mode
 * No BSP, no ThreadX, just pure bare-metal code
 */

#include <stdint.h>

/* Heartbeat location in shared memory */
#define HEARTBEAT_ADDR 0x3FD08000
volatile uint32_t *heartbeat = (volatile uint32_t *)HEARTBEAT_ADDR;

/* Simple delay function */
static void delay(void) {
    for (volatile int i = 0; i < 1000000; i++);
}

/* Main function */
int main(void)
{
    /* Write heartbeat immediately */
    *heartbeat = 0xDEADBEEF;

    /* Simple counter loop */
    uint32_t counter = 0;
    while (1) {
        counter++;
        *heartbeat = 0x12340000 + (counter & 0xFFFF);
        delay();
    }

    return 0;
}

/* Minimal startup code - no BSP initialization */
void _start(void) __attribute__((naked, section(".boot")));
void _start(void)
{
    /* Set stack pointer */
    __asm__ volatile(
        "ldr sp, =_stack\n"
        "b main\n"
    );
}
